rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email == 'calebmapatha@gmail.com' &&
        request.auth.token.email_verified == true;
    }

    // Verification documents (certified ID, academic certificates, HPCSA
    // certificate) uploaded by a practitioner during their trial. These are
    // sensitive identity documents: ONLY the owner and the admin may read or
    // write them — never other users. Images or PDFs up to 10 MB.
    match /verification-docs/{uid}/{fileName} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpe?g|webp)|application/pdf');
      allow delete: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }

    // Profile photos live at profile-photos/{type}/{uid}.{ext}.
    // Anyone signed in may view a photo (provider photos are shown to
    // patients and vice-versa), but a user may only write/replace/delete
    // a file whose name starts with their own uid, and only small images.
    match /profile-photos/{type}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && fileName.matches('^' + request.auth.uid + '\\..+')
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpe?g|webp|gif)');
      allow delete: if request.auth != null
        && fileName.matches('^' + request.auth.uid + '\\..+');
    }

    // Encrypted client-file vault blobs (AES-GCM ciphertext with the IV
    // prepended, uploaded as application/octet-stream). Owner-ONLY — not
    // even admin — matching the zero-knowledge Firestore vault rules.
    match /vault/{uid}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.size < 11 * 1024 * 1024
        && request.resource.contentType == 'application/octet-stream';
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Deny everything else.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
