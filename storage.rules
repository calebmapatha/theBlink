rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile photos live at profile-photos/{type}/{uid}.{ext}.
    // Anyone signed in may view a photo (provider photos are shown to
    // patients and vice-versa), but a user may only write/replace/delete
    // a file whose name starts with their own uid, and only small images.
    match /profile-photos/{type}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && fileName.matches('^' + request.auth.uid + '\\..+')
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpe?g|webp|gif)');
      allow delete: if request.auth != null
        && fileName.matches('^' + request.auth.uid + '\\..+');
    }

    // Deny everything else.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
