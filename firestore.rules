rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'calebmapatha@gmail.com';
    }
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // Keys on a provider doc that only trusted code may write:
    //  - subscription/trial state + rating aggregates: Cloud Functions + admin
    //    (a doctor must not grant themselves a subscription or reset a trial)
    //  - approvalStatus / suspended: Super Admin moderation only
    //    (a provider must never approve or un-suspend themselves)
    function touchesProviderTrustedKeys(keys) {
      return keys.hasAny([
        'subscriptionActive', 'subscriptionStatus', 'subscriptionPlan', 'subscriptionStarted',
        'trialUsed', 'trialStarted', 'trialEndsAt',
        'ratingCount', 'ratingAvg', 'suspended'
      ]);
    }

    // Providers: any authed user can read ACTIVE profiles (or their own).
    // Admin can read everything for moderation.
    match /providers/{uid} {
      allow read: if isSignedIn() &&
        (isAdmin() || resource == null || resource.data.subscriptionActive == true || request.auth.uid == uid);

      allow create: if isSignedIn() && (
        isAdmin() ||
        (request.auth.uid == uid &&
          !touchesProviderTrustedKeys(request.resource.data.keys()) &&
          (!('approvalStatus' in request.resource.data) || request.resource.data.approvalStatus == 'pending'))
      );

      allow update: if isSignedIn() && (
        isAdmin() ||
        (request.auth.uid == uid &&
          !touchesProviderTrustedKeys(changedKeys()) &&
          !changedKeys().hasAny(['approvalStatus'])) ||
        // Any signed-in user may bump the view counter — but only by exactly
        // one, so it can't be reset or inflated arbitrarily.
        (changedKeys().hasOnly(['profileViews']) &&
          request.resource.data.profileViews == resource.data.get('profileViews', 0) + 1)
      );

      allow delete: if isSignedIn() && (request.auth.uid == uid || isAdmin());

      // Pre-screening documents (T&Cs, intake consent…) the provider uploads
      // for patients to sign before booking. Any signed-in user may read them
      // (patients must review before signing); only the owner or admin writes.
      match /screeningDocs/{docId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      }
    }

    // Signed pre-screening consents: created by the signing patient, readable
    // by the patient, the provider concerned, and admin. Immutable once made.
    match /consents/{id} {
      allow create: if isSignedIn() &&
        request.resource.data.patientUid == request.auth.uid;
      allow read: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.patientUid ||
        request.auth.uid == resource.data.providerUid
      );
      allow update, delete: if false;
    }

    // Appointments: created by the patient; readable/updatable by either party.
    // Admin may read for platform analytics and dispute handling.
    match /appointments/{id} {
      allow create: if isSignedIn() &&
        request.resource.data.patientUid == request.auth.uid;
      allow read: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.patientUid ||
        request.auth.uid == resource.data.providerUid
      );
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.patientUid ||
        request.auth.uid == resource.data.providerUid
      ) &&
        // Neither party may reassign the appointment to someone else (which
        // would leak the embedded health snapshot) or forge its creation time.
        !changedKeys().hasAny(['patientUid', 'providerUid', 'createdAt']) &&
        (!changedKeys().hasAny(['status']) ||
          request.resource.data.status in ['pending', 'confirmed', 'completed', 'no-show', 'cancelled']);
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.patientUid || isAdmin());
    }

    // Patients: readable by the patient themselves, their linked doctor, and
    // admin (account management). Writable/deletable by the patient or admin.
    match /patients/{uid} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid == uid ||
        (resource != null && resource.data.linkedDoctorUid == request.auth.uid)
      );
      allow write:  if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow delete: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    // Ratings: readable only by the patient who wrote it, the rated provider,
    // or admin. Immutable once made.
    //
    // A rating may only be created by the patient of the appointment it is
    // keyed on, for that appointment's provider, once the session was actually
    // booked (confirmed/completed), and every score must be 1–5. Without these
    // checks any signed-in user could mass-forge ratings with unbounded values
    // and destroy (or inflate) any provider's aggregates.
    match /ratings/{appointmentId} {
      function appt() {
        return get(/databases/$(database)/documents/appointments/$(appointmentId)).data;
      }
      function validScore(key) {
        return request.resource.data[key] is number &&
               request.resource.data[key] >= 1 &&
               request.resource.data[key] <= 5;
      }

      allow read: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.patientUid ||
        request.auth.uid == resource.data.providerId
      );
      allow create: if isSignedIn() &&
        request.resource.data.patientUid == request.auth.uid &&
        exists(/databases/$(database)/documents/appointments/$(appointmentId)) &&
        appt().patientUid == request.auth.uid &&
        appt().providerUid == request.resource.data.providerId &&
        appt().status in ['confirmed', 'completed'] &&
        validScore('communication') && validScore('empathy') &&
        validScore('professionalism') && validScore('treatmentPlan') &&
        validScore('overall') &&
        (!('comment' in request.resource.data) ||
          (request.resource.data.comment is string && request.resource.data.comment.size() <= 2000));
      allow update, delete: if false;
    }

    // User app data — strictly owner-only.
    match /users/{uid}/data/{key} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // Reports: any signed-in user may report a provider/user; only admin can
    // read, resolve, or delete reports.
    match /reports/{id} {
      allow create: if isSignedIn() &&
        request.resource.data.reporterUid == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    // Announcements: written by admin, readable by everyone signed in.
    match /announcements/{id} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // Admin audit log: append-only by admin, readable by admin.
    match /adminLogs/{id} {
      allow create: if isAdmin();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // Platform configuration / feature flags: world-readable (signed in),
    // admin-writable.
    match /config/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Default deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
