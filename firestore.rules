rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Providers: any authenticated user can read active profiles; only the provider (or admin) can write
    match /providers/{uid} {
      allow read: if request.auth != null &&
        (resource == null || resource.data.subscriptionActive == true || request.auth.uid == uid);
      allow write: if request.auth != null && (
        request.auth.uid == uid ||
        request.auth.token.email == 'calebmapatha@gmail.com'
      );
    }

    // Appointments: patient or provider of that appointment can read/write; any authed user can create
    match /appointments/{id} {
      allow create: if request.auth != null &&
        request.resource.data.patientUid == request.auth.uid;
      allow read, update: if request.auth != null && (
        request.auth.uid == resource.data.patientUid ||
        request.auth.uid == resource.data.providerUid
      );
    }

    // Patients: the patient can read/write their own record; providers can read (for appointment context)
    match /patients/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Ratings: any authed user can read; only the patient who owns the rating can create it; no updates/deletes
    match /ratings/{appointmentId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.patientUid == request.auth.uid;
      allow update, delete: if false;
    }
    // User app data (habits, tasks, brain dump, etc.) — synced across devices
    match /users/{uid}/data/{key} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
