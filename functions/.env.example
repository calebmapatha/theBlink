# Copy to functions/.env before deploying with live billing.
# Without PAYFAST_MERCHANT_ID/PAYFAST_MERCHANT_KEY, paid plans activate in
# demo mode (no charge), so deploying before these are set does no harm.

# Merchant ID + Merchant Key from PayFast: Settings > Integration.
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a

# Salt Passphrase set on the same PayFast Integration page. Required for
# recurring/subscription billing — must match exactly, and PayFast will
# reject every checkout if this is set on one side but not the other.
PAYFAST_PASSPHRASE=

# 'sandbox' (default, safe — use PayFast's sandbox card to test) or 'live'.
# Always prove the full checkout -> ITN -> activation flow in sandbox first.
PAYFAST_MODE=sandbox

# Where PayFast returns the doctor after checkout (your deployed app).
PAYMENT_CALLBACK_URL=https://calebmapatha.github.io/theBlink/

# Optional override for the ITN notify_url PayFast posts to. Defaults to this
# project's deployed paymentWebhook URL — only set this if that ever changes
# (e.g. a different Firebase project or a custom domain).
PAYFAST_NOTIFY_URL=
